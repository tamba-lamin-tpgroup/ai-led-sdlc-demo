{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "outputStyle": "lead-developer",
  "statusLine": {
    "type": "command",
    "command": "bash $CLAUDE_PROJECT_DIR/.claude/scripts/statusline.sh"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(//$CLAUDE_PROJECT_DIR/**)",
      "Edit(//$CLAUDE_PROJECT_DIR/**)",
      "Write(//$CLAUDE_PROJECT_DIR/**)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git restore:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git rev-parse:*)",
      "Bash(git stash:*)",
      "Bash(git config --local --get *)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo view:*)",
      "Bash(gh project:*)",
      "Bash(gh api:*)",
      "Bash(gh run:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(python3:*)",
      "Bash(uvx:*)",
      "Bash(uv:*)",
      "Bash(agent-browser:*)",
      "Bash(sg:*)",
      "Bash(tokei:*)",
      "Bash(repomix:*)",
      "Bash(rtk:*)",
      "Bash(pdftotext:*)",
      "Bash(jq:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(awk:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(./bin/*)",
      "Bash(.claude/scripts/*)",
      "WebSearch",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:vite.dev)",
      "WebFetch(domain:vitejs.dev)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:supabase.com)",
      "WebFetch(domain:vercel.com)",
      "WebFetch(domain:playwright.dev)",
      "WebFetch(domain:design.tpgroupsl.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:ntb.gov.sl)",
      "WebFetch(domain:tourismsierraleone.com)",
      "WebFetch(domain:visitsierraleone.org)",
      "WebFetch(domain:sierraleoneheritage.org)",
      "WebFetch(domain:sierra-leone.org)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D*)",
      "Bash(git clean -f*)",
      "Bash(git commit *--no-verify*)",
      "Bash(gh pr merge:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Read(//**/.env)",
      "Read(//**/.env.*)",
      "Read(//**/*.pem)",
      "Read(//**/*.key)",
      "Read(//**/id_rsa*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/user-prompt-submit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pre-tool-bash.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pre-tool-edit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/stop-session.sh"
          }
        ]
      }
    ]
  }
}
